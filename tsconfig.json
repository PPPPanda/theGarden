{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "assets/scripts/core/types.ts"
  ],
  "exclude": [
    "node_modules",
    "skills",
    "**/*.spec.ts",
    "**/*.d.ts",
    "assets/scripts/core/GameManager.ts",
    "assets/scripts/core/ItemDB.ts",
    "assets/scripts/ui/GridView.ts"
  ]
}
